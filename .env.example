# Copy to .env — never commit this file

# Anthropic API key (console.anthropic.com)
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Railway proxy URL (after deployment)
VITE_PROXY_URL=https://your-railway-app.up.railway.app

# Your Vercel frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Optional: VAPID keys for push notifications
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@email.com
